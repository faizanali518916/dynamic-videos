{
  "name": "my-video",
  "version": "1.0.0",
  "description": "My Remotion video",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/captions": "4.0.477",
    "@remotion/cli": "4.0.477",
    "@remotion/install-whisper-cpp": "4.0.477",
    "@remotion/tailwind-v4": "4.0.477",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.477",
    "tailwindcss": "4.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.477",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "node ./node_modules/@remotion/cli/remotion-cli.js studio src/index.ts",
    "render": "node ./node_modules/@remotion/cli/remotion-cli.js render src/index.ts InfographicVideo out/infographic.mp4",
    "still": "node ./node_modules/@remotion/cli/remotion-cli.js still src/index.ts InfographicVideo out/preview.png --frame=35",
    "build:builder": "node scripts/build-template-builder.mjs",
    "build": "node ./node_modules/@remotion/cli/remotion-cli.js bundle src/index.ts",
    "caption": "node ./scripts/generate-project-captions.mjs",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
