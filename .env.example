PORT=4173

# Optional. Used by the render worker if Chrome is not auto-detected.
REMOTION_BROWSER_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe

# Google Drive + Gmail use the same OAuth credentials.
# Required scopes: drive.file and gmail.send.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional. Upload into a specific Drive folder.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SHARE_ANYONE=true

# Required for sending the completion email through Gmail.
GMAIL_FROM=
